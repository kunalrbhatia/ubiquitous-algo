{
  "name": "ratio-double-calendar-daemon",
  "version": "1.0.0",
  "description": "Banknifty Monthly Calendar Spread Option Strategy Daemon using Angel One SmartAPI",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prep": "ts-node src/scripts/dailyPrep.ts",
    "generate-basket": "ts-node src/scripts/generateBasket.ts",
    "prep:prod": "node dist/scripts/dailyPrep.js",
    "test": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "verify": "pnpm format:check && pnpm lint && pnpm test && pnpm build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "lodash": "^4.17.21",
    "node-cron": "^3.0.3",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.11.24",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
